<%- include('partials/header', { pageTitle: 'Admin Login' }) %>

<section class="flex-1 flex items-center justify-center min-h-[80vh] px-4">
  <div class="w-full max-w-md">

    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-500 shadow-lg shadow-brand-500/30 mb-4">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <h1 class="font-display text-2xl font-700 text-gray-900 dark:text-white">Admin Access</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">LazyCoders Dashboard</p>
    </div>

    <!-- Error -->
    <% if (error) { %>
    <div class="mb-4 p-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-sm text-red-600 dark:text-red-400 flex items-center gap-2">
      <span>⚠️</span> <%= error %>
    </div>
    <% } %>

    <!-- Form -->
    <div class="form-card">
      <form action="/admin/login" method="POST">
        <div class="form-group">
          <label for="username" class="form-label">Username</label>
          <input type="text" id="username" name="username" class="form-input" placeholder="lazycoders" required autocomplete="username"/>
        </div>
        <div class="form-group">
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required autocomplete="current-password"/>
        </div>
        <button type="submit" class="w-full btn-primary justify-center py-3.5 mt-2">
          Sign In
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
        </button>
      </form>
    </div>

    <p class="text-center text-sm text-gray-400 mt-4">
      <a href="/" class="hover:text-brand-500 transition-colors">← Back to site</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
