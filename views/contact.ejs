<%- include('partials/header', { pageTitle: 'Contact' }) %>

<section class="pt-20 pb-12 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="blob blob-2" style="opacity:0.35"></div>
    <div class="absolute inset-0 bg-grid opacity-[0.03] dark:opacity-[0.06]"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="section-label">Say Hello</p>
    <h1 class="font-display text-5xl sm:text-6xl font-extrabold text-gray-900 dark:text-white mt-3 mb-5">
      Get in <span class="text-brand-500">Touch</span>
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
      Have a project idea, collaboration request, or just want to say hi? We'd love to hear from you.
    </p>
  </div>
</section>

<section class="py-12 pb-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- LEFT: Info cards -->
      <div class="lg:col-span-2 space-y-5">
        <div class="contact-info-card">
          <div class="w-10 h-10 rounded-xl bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-500 mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-display font-700 text-gray-900 dark:text-white mb-1">Email Us</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Drop a message via the form and we'll get back within 24 hours.</p>
        </div>

        <div class="contact-info-card">
          <div class="w-10 h-10 rounded-xl bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-500 mb-3">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </div>
          <h3 class="font-display font-700 text-gray-900 dark:text-white mb-1">GitHub</h3>
          <a href="https://github.com/teamlazycoder" target="_blank" class="text-sm text-brand-500 hover:underline">github.com/lazycoders</a>
        </div>

        <div class="contact-info-card">
          <div class="w-10 h-10 rounded-xl bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-500 mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-display font-700 text-gray-900 dark:text-white mb-1">Location</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Maharashtra, India 🇮🇳</p>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div class="lg:col-span-3">
        <div class="form-card">

          <!-- Success Message -->
          <% if (success) { %>
          <div class="mb-6 p-4 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 flex items-start gap-3 animate-slide-up">
            <span class="text-green-500 text-xl mt-0.5">✅</span>
            <div>
              <p class="font-600 text-green-800 dark:text-green-300">Message sent successfully!</p>
              <p class="text-sm text-green-600 dark:text-green-400 mt-0.5">We'll get back to you within 24 hours. Thanks for reaching out!</p>
            </div>
          </div>
          <% } %>

          <!-- Error Message -->
          <% if (error) { %>
          <div class="mb-6 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 flex items-start gap-3 animate-slide-up">
            <span class="text-red-500 text-xl mt-0.5">⚠️</span>
            <div>
              <p class="font-600 text-red-800 dark:text-red-300">Oops, something went wrong</p>
              <p class="text-sm text-red-600 dark:text-red-400 mt-0.5"><%= error %></p>
            </div>
          </div>
          <% } %>

          <h2 class="font-display text-2xl font-700 text-gray-900 dark:text-white mb-6">Send us a message</h2>

          <form action="/contact" method="POST" id="contactForm" novalidate>
            <!-- Name -->
            <div class="form-group">
              <label for="name" class="form-label">Your Name <span class="text-brand-500">*</span></label>
              <input
                type="text" id="name" name="name"
                placeholder="e.g. Rahul Sharma"
                class="form-input"
                required minlength="2"
              />
              <p class="form-error hidden" id="nameError">Please enter your full name.</p>
            </div>

            <!-- Email -->
            <div class="form-group">
              <label for="email" class="form-label">Email Address <span class="text-brand-500">*</span></label>
              <input
                type="email" id="email" name="email"
                placeholder="you@example.com"
                class="form-input"
                required
              />
              <p class="form-error hidden" id="emailError">Please enter a valid email address.</p>
            </div>

            <!-- Message -->
            <div class="form-group">
              <label for="message" class="form-label">Message <span class="text-brand-500">*</span></label>
              <textarea
                id="message" name="message"
                rows="5"
                placeholder="Tell us about your project, idea, or just say hi..."
                class="form-input resize-none"
                required minlength="10"
              ></textarea>
              <p class="form-error hidden" id="msgError">Message must be at least 10 characters.</p>
            </div>

            <button type="submit" id="submitBtn" class="w-full btn-primary justify-center py-3.5">
              <span id="btnText">Send Message</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
// Client-side form validation
document.getElementById('contactForm').addEventListener('submit', function(e) {
  let valid = true;

  const name    = document.getElementById('name');
  const email   = document.getElementById('email');
  const message = document.getElementById('message');

  // Reset errors
  ['nameError','emailError','msgError'].forEach(id => {
    document.getElementById(id).classList.add('hidden');
  });
  [name, email, message].forEach(el => el.classList.remove('border-red-400'));

  if (!name.value.trim() || name.value.trim().length < 2) {
    document.getElementById('nameError').classList.remove('hidden');
    name.classList.add('border-red-400');
    valid = false;
  }

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRe.test(email.value.trim())) {
    document.getElementById('emailError').classList.remove('hidden');
    email.classList.add('border-red-400');
    valid = false;
  }

  if (!message.value.trim() || message.value.trim().length < 10) {
    document.getElementById('msgError').classList.remove('hidden');
    message.classList.add('border-red-400');
    valid = false;
  }

  if (!valid) {
    e.preventDefault();
    return;
  }

  // Show loading state
  const btn = document.getElementById('submitBtn');
  document.getElementById('btnText').textContent = 'Sending...';
  btn.disabled = true;
  btn.classList.add('opacity-75');
});
</script>

<%- include('partials/footer') %>
